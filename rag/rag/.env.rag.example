# ==============================================================================
# VOLTSENTINEL RAG LOCAL ENVIRONMENT EXAMPLE
# Do not commit a real .env file.
# ==============================================================================

OPENAI_API_KEY="sk-proj-replace-me"
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"
OPENAI_SYNTHESIS_MODEL="gpt-4o"

SUPABASE_DB_URL="postgresql://postgres:<password>@<host>:5432/postgres?sslmode=require"

# Upstash REST API values, not TCP Redis values.
UPSTASH_REDIS_REST_URL="https://your-cache.upstash.io"
UPSTASH_REDIS_REST_TOKEN="replace-me"
RAG_CACHE_TTL_SECONDS="3600"

# Azure Document Intelligence.
AZURE_DOC_INTEL_ENDPOINT="https://your-docintel.cognitiveservices.azure.com/"
AZURE_DOC_INTEL_KEY="replace-me"

# Runtime policy.
MIN_RAG_SIMILARITY="0.62"
HUMAN_APPROVAL_REQUIRED_FOR_CRM="true"
HIGH_VALUE_USD_THRESHOLD="5000"
MAX_AGENT_RETRY_ITERATIONS="3"

# Salesforce sandbox connector.
SALESFORCE_SANDBOX_URL="https://your-org--devsb.sandbox.my.salesforce.com"
SALESFORCE_OAUTH_TOKEN_URL="https://test.salesforce.com/services/oauth2/token"
SF_CONSUMER_KEY="replace-me"
SF_CONSUMER_SECRET="replace-me"

# ==============================================================================
# OPTIONAL HEADROOM CONTEXT OPTIMIZATION
# ==============================================================================
HEADROOM_ENABLED="false"
HEADROOM_MIN_INPUT_TOKENS="4000"
HEADROOM_PRESERVE_CITATIONS="true"
HEADROOM_PRESERVE_NUMBERS="true"
HEADROOM_PRESERVE_DATES="true"
HEADROOM_PRESERVE_SECTION_REFERENCES="true"

# ==============================================================================
# RAG OBSERVABILITY / CONTROL TOWER
# ==============================================================================
RAG_OBSERVABILITY_JSONL="./rag_observability_events.jsonl"
CONTROL_TOWER_ENABLED="true"
